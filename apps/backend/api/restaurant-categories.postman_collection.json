{
  "info": {
    "name": "Restaurant Categories API",
    "_postman_id": "0b1b5a9f-2d21-4f59-9f5a-restaurant-categories",
    "description": "Postman collection for admin auth and restaurant categories endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.access_token) {",
                  "    pm.collectionVariables.set('token', json.data.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Restaurant Categories",
      "item": [
        {
          "name": "List Restaurant Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories?per_page=15",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          }
        },
        {
          "name": "List All Restaurant Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories?all=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories"
              ],
              "query": [
                {
                  "key": "all",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Show Restaurant Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories",
                "{{categoryId}}"
              ]
            }
          }
        },
        {
          "name": "Create Restaurant Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Italian Food\",\n  \"slug\": \"italian-food\"\n}"
            }
          }
        },
        {
          "name": "Update Restaurant Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories",
                "{{categoryId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Name\"\n}"
            }
          }
        },
        {
          "name": "Delete Restaurant Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/restaurant-categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "restaurant-categories",
                "{{categoryId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
